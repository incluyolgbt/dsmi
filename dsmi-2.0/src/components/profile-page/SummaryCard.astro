02C21.9901 13.5727 20.4275 12.0102 18.5 12.0102C16.5725 12.0102 15.0099 13.5727 15.0099 15.5002Z" fill="#1A1A2E"></path> </g></svg>`,
    modalities: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="1"></circle><circle cx="19" cy="12" r="1"></circle><circle cx="5" cy="12" r="1"></circle></svg>`,
    pronouns: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>`,
    communityRelation: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>`,
};
---

<div class="summary-card">
    <div class="summary-card-section">
        <div class="summary-card-section-header">
            <span class="summary-card-icon">
                <Fragment set:html={sectionIcons.location} />
            </span>
            <h2 class="summary-card-section-title">Ubicación</h2>
        </div>
        <p class="summary-card-section-content">
            {city}, {state}
        </p>
    </div>

    <div class="summary-card-section">
        <div class="summary-card-section-header">
            <span class="summary-card-icon">
                <Fragment set:html={sectionIcons.price} />
            </span>
            <h2 class="summary-card-section-title">Rango de precio</h2>
        </div>
        <p class="summary-card-section-content">
            {
                priceRange[0] === priceRange[1] ? (
                    <span aria-label={`${priceRange[0]} pesos mexicanos`}>
                        ${priceRange[0]} MXN
                    </span>
                ) : (
                    <span
                        aria-label={`${priceRange[0]} pesos mexicanos a ${priceRange[1]} pesos mexicanos`}
                    >
                        ${priceRange[0]} MXN - ${priceRange[1]} MXN
                    </span>
                )
            }
        </p>
    </div>

    {
        patientFocus.length > 0 && (
            <div class="summary-card-section">
                <div class="summary-card-section-header">
                    <span class="summary-card-icon">
                        <Fragment set:html={sectionIcons.patientFocus} />
                    </span>
                    <h2 class="summary-card-section-title">
                        Áreas de especialidad
                    </h2>
                </div>
                <div class="summary-card-pills-container">
                    {patientFocus.map((item) => (
                        <span class="summary-card-pill">{item}</span>
                    ))}
                </div>
            </div>
        )
    }

    {
        focusAreas.length > 0 && (
            <div class="summary-card-section">
                <div class="summary-card-section-header">
                    <span class="summary-card-icon">
                        <Fragment set:html={sectionIcons.focusAreas} />
                    </span>
                    <h2 class="summary-card-section-title">Enfoque</h2>
                </div>
                <div class="summary-card-pills-container">
                    {focusAreas.map((item) => (
                        <span class="summary-card-pill">{item}</span>
                    ))}
                </div>
            </div>
        )
    }

    {
        modalities.length > 0 && (
            <div class="summary-card-section">
                <div class="summary-card-section-header">
                    <span class="summary-card-icon">
                        <Fragment set:html={sectionIcons.modalities} />
                    </span>
                    <h2 class="summary-card-section-title">Modalidades</h2>
                </div>
                <div class="summary-card-pills-container">
                    {modalities.map((modality) => (
                        <span class="summary-card-pill">{modality}</span>
                    ))}
                </div>
            </div>
        )
    }

    {
        pronouns.length > 0 && (
            <div class="summary-card-section">
                <div class="summary-card-section-header">
                    <span class="summary-card-icon">
                        <Fragment set:html={sectionIcons.pronouns} />
                    </span>
                    <h2 class="summary-card-section-title">Pronombres</h2>
                </div>
                <div class="summary-card-pills-container">
                    {pronouns.map((pronoun) => (
                        <span class="summary-card-pill">{pronoun}</span>
                    ))}
                </div>
            </div>
        )
    }

    {
        typeof communityAffiliation === 'boolean' && (
            <div class="summary-card-section">
                <div class="summary-card-section-header">
                    <span class="summary-card-icon">
                        <Fragment set:html={sectionIcons.communityRelation} />
                    </span>
                    <h2 class="summary-card-section-title">
                        Relación con la comunidad
                    </h2>
                </div>
                {communityAffiliation && (
                    <p class="summary-card-section-content">
                        Se identifica cómo LGBTQ+
                    </p>
                )}
                {communityAffiliation === false && (
                    <p class="summary-card-section-content">
                        Se identifica cómo aliade
                    </p>
                )}
            </div>
        )
    }
</div>

<style>
    .summary-card {
        background: var(--primary-light);
        border-radius: 32px;
        padding: 48px;
        margin: 0;
        width: 100%;
        max-width: 100%;
        min-width: 0;
        box-sizing: border-box;
    }

    .summary-card-section {
        margin-bottom: 28px;
    }

    .summary-card-section:last-child {
        margin-bottom: 0;
    }

    .summary-card-section-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
    }

    .summary-card-icon {
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .summary-card-section-title {
        font-size: 18px;
        font-weight: 700;
        color: var(--primary-dark);
        margin: 0;
        text-transform: uppercase;
        font-family: 'Red Hat Display', sans-serif;
        letter-spacing: 0.7px;
    }

    .summary-card-section-content {
        font-size: 16px;
        color: var(--secondary-dark);
        margin: 0 0 0 36px;
        line-height: 1.5;
        font-family: 'Red Hat Display', sans-serif;
        font-weight: 500;
    }

    .summary-card-pills-container {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-left: 36px;
    }

    .summary-card-pill {
        background-color: rgba(255, 255, 255, 0.5);
        color: var(--secondary-dark);
        padding: 10px 24px;
        border-radius: 24px;
        font-size: 16px;
        font-weight: 500;
        white-space: nowrap;
        display: inline-block;
        font-family: 'Red Hat Display', sans-serif;
    }

    @media (max-width: 640px) {
        .summary-card {
            padding: 35px;
            border-radius: 24px;
        }

        .summary-card-title {
            font-size: 30px;
            margin-bottom: 24px;
        }

        .summary-card-section {
            margin-bottom: 28px;
        }

        .summary-card-section-header {
            gap: 10px;
            margin-bottom: 10px;
        }

        .summary-card-icon {
            width: 20px;
            height: 20px;
        }

        .summary-card-icon :global(svg) {
            width: 20px;
            height: 20px;
        }

        .summary-card-pill {
            font-size: 14px;
            padding: 8px 16px;
        }

        .summary-card-pills-container {
            gap: 10px;
            margin-left: 30px;
        }

        .summary-card-section-content {
            margin-left: 30px;
        }
    }
</style>
