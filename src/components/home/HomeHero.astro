---
import { Image } from 'astro:assets';
import heroImage from '../../assets/hero.webp';
---

<section class="home-hero" aria-labelledby="home-hero-title">
    <div class="home-hero__content">
        <div class="home-hero__copy">
            <h2
                id="home-hero-title"
                class="home-hero__title"
                aria-label="Tu identidad importa, tu salud mental también."
            >
                <span aria-hidden="true"
                    >Tu <strong>identidad</strong> importa,</span
                >
                <span aria-hidden="true"
                    >tu <strong>salud mental</strong> también.</span
                >
            </h2>
            <p class="home-hero__description">
                Encuentra aquí profesionistas de la salud mental
                hispanohablantes con perspectiva LGBTQ+.
            </p>
            <a
                class="home-hero__button"
                href="/perfiles/"
                data-umami-event="home_hero_cta_clicked"
            >
                Explorar los perfiles
            </a>
        </div>

        <div class="home-hero__media" aria-hidden="true">
            <Image
                src={heroImage}
                alt=""
                widths={[360, 520, 720, 920, 1102]}
                sizes="(max-width: 700px) 82vw, (max-width: 1100px) 42vw, 560px"
                class="home-hero__image"
                loading="eager"
                fetchpriority="high"
                decoding="async"
            />
        </div>
    </div>
</section>

<style>
    .home-hero {
        width: 100%;
        padding: clamp(2.25rem, 5vw, 3.75rem) clamp(1rem, 4vw, 4.75rem)
            clamp(2rem, 6vw, 4.5rem);
        background-color: #fff;
    }

    .home-hero__content {
        display: grid;
        grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
        align-items: center;
        gap: clamp(1rem, 3vw, 3rem);
        max-width: 1780px;
        min-height: clamp(420px, 43vw, 620px);
        margin: 0 auto;
        padding: 0 clamp(2rem, 5vw, 5.25rem);
        overflow: visible;
        background-color: var(--primary-light);
        border-radius: clamp(2.25rem, 5vw, 5.5rem);
    }

    .home-hero__copy {
        min-width: 0;
        color: #000;
        font-family: 'Red Hat Display', sans-serif;
    }

    .home-hero__title {
        margin: 0;
        max-width: 960px;
        font-family: 'Gelasio', sans-serif;
        font-size: clamp(3rem, 4vw, 5rem);
        font-weight: 400;
        line-height: 1.25;
        letter-spacing: 0;
    }

    .home-hero__title strong {
        font-weight: 800;
    }

    .home-hero__title span {
        display: block;
        white-space: nowrap;
    }

    .home-hero__description {
        max-width: 790px;
        margin: clamp(1.75rem, 3vw, 2.75rem) 0 0;
        font-size: clamp(1.35rem, 2.2vw, 2.25rem);
        font-weight: 400;
        line-height: 1.4;
        letter-spacing: 0;
    }

    .home-hero__button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 58px;
        margin-top: clamp(1.75rem, 3vw, 3rem);
        padding: 14px 24px;
        border-radius: 12px;
        background-color: var(--primary-dark);
        color: var(--light-primary-text);
        font-family: 'Red Hat Display', sans-serif;
        font-size: 15px;
        font-weight: 600;
        letter-spacing: 0.5px;
        line-height: 1.1;
        text-align: center;
        text-decoration: none;
        text-transform: uppercase;
        transition: opacity 0.2s ease;
    }

    .home-hero__button:hover {
        opacity: 0.9;
    }

    .home-hero__button:focus-visible {
        outline: 3px solid var(--primary-dark);
        outline-offset: 3px;
        opacity: 0.9;
    }

    .home-hero__media {
        align-self: end;
        justify-self: end;
        width: min(100%, 620px);
        margin-right: clamp(-2rem, -2vw, -0.75rem);
        transform: translateY(2rem);
    }

    .home-hero__image {
        display: block;
        width: 120%;
        height: auto;
    }

    @media (max-width: 1100px) {
        .home-hero__content {
            grid-template-columns: minmax(0, 1fr) minmax(240px, 0.72fr);
            min-height: 0;
        }

        .home-hero__title {
            font-size: clamp(2.35rem, 4vw, 3.25rem);
        }

        .home-hero__description {
            font-size: clamp(1.2rem, 2.6vw, 1.75rem);
        }
    }

    @media (max-width: 760px) {
        .home-hero {
            padding: 1.75rem 1rem 2.5rem;
        }

        .home-hero__content {
            grid-template-columns: 1fr;
            gap: 1.5rem;
            padding: clamp(2rem, 9vw, 3rem) clamp(1.4rem, 7vw, 2.25rem) 0;
            border-radius: 2.25rem;
        }

        .home-hero__title {
            font-size: clamp(1.75rem, 6.5vw, 3.4rem);
            line-height: 1.14;
        }

        .home-hero__description {
            margin-top: 1.5rem;
            font-size: clamp(1.1rem, 5vw, 1.45rem);
            line-height: 1.38;
        }

        .home-hero__button {
            width: 100%;
            margin-top: 1.75rem;
            font-size: 14px;
        }

        .home-hero__media {
            justify-self: center;
            width: min(92%, 430px);
            margin: 0 0 -1.25rem;
            transform: none;
        }

        .home-hero__image {
            width: 100%;
        }
    }

    @media (max-width: 420px) {
        .home-hero__content {
            border-radius: 1.75rem;
        }

        .home-hero__title {
            font-size: clamp(1.25rem, 6vw, 2.85rem);
        }
    }
</style>
