const getSocialIcon = (platform: string) => {
    const key = platform.toLowerCase() as keyof typeof socialIcons;
    return socialIcons[key] || socialIcons.website;
};

const splitEmail = contact.email ? contact.email.split('@') : [];
---

<div class="details-card">
    <!-- Biography -->
    <details-card-section class="details-card-section">
        <h1 class="details-card-section-title">Semblanza</h1>
        <p class="biography">{biography}</p>
    </details-card-section>

    <div class="divider"></div>

    <!-- Services  -->
    <details-card-section class="details-card-section">
        <h1 class="details-card-section-title">Servicios</h1>
        <ServicesList services={services} />
    </details-card-section>

    <div class="divider"></div>

    <details-card-section class="details-card-section extra-padding">
        <h2 class="details-card-section-title">Contacto</h2>

        <div class="details-card-two-columns">
            <!-- Contact Information details-card-section -->
            <div class="column">
                <div class="contact-info">
                    {
                        contact.phoneNumber && (
                            <div class="contact-item">
                                <span class="contact-icon">
                                    <Fragment set:html={socialIcons.phone} />
                                </span>
                                <a
                                    href={`tel:${contact.phoneNumber.replace(
                                        /\D/g,
                                        ''
                                    )}`}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="contact-link"
                                    aria-label={`Llamar a ${contact.phoneNumber}`}
                                    data-umami-event="pdp_contact_click"
                                    data-umami-event-contact-type="phone"
                                    data-umami-event-profile={`${profileName}:phone`}
                                >
                                    {contact.phoneNumber}
                                </a>
                            </div>
                        )
                    }
                    {
                        contact.email && (
                            <div class="contact-item">
                                <span class="contact-icon">
                                    <Fragment set:html={socialIcons.email} />
                                </span>
                                <div
                                    class="email"
                                    aria-label={'Correo electrónico'}
                                >
                                    <!-- prettier-ignore -->
                                    {splitEmail.at(0)}<span>@</span>{splitEmail.at(1)}
                                </div>
                            </div>
                        )
                    }
                    {
                        contact.whatsApp && (
                            <div class="contact-item">
                                <span class="contact-icon">
                                    <Fragment set:html={socialIcons.whatsapp} />
                                </span>
                                <a
                                    href={`https://wa.me/${contact.whatsApp.replace(
                                        '+52',
                                        '521'
                                    )}`}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="contact-link"
                                    aria-label={`Iniciar conversación por WhatsApp`}
                                    data-umami-event="pdp_contact_click"
                                    data-umami-event-contact-type="whatsapp"
                                    data-umami-event-profile={`${profileName}:whatsApp`}
                                >
                                    Contactar por WhatsApp
                                </a>
                            </div>
                        )
                    }
                </div>
            </div>

            <div class="vertical-divider"></div>

            <div class="column">
                <!-- Social Media details-card-section -->
                <div class="social-media">
                    {
                        socialMedia.map((social) => (
                            <a
                                href={social.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="contact-item contact-link"
                                aria-label={social.name}
                                data-umami-event="pdp_contact_click"
                                data-umami-event-contact-type="social_media"
                                data-umami-event-profile={`${profileName}:${social.name}`}
                            >
                                <span class="contact-icon">
                                    <Fragment
                                        set:html={getSocialIcon(social.name)}
                                    />
                                </span>
                                <span>{social.handle}</span>
                            </a>
                        ))
                    }
                </div>
            </div>
        </div>
    </details-card-section>

    {
        Boolean(professionalId || academicTitles?.length) && (
            <div class="divider" />
        )
    }

    <!-- Professional ID details-card-section -->
    {
        professionalId && (
            <details-card-section class="details-card-section">
                <h2 class="details-card-section-title">Formación</h2>
                <ul class="details-card-professional-info">
                    {!academicTitles?.length && (
                        <li>
                            <b>Cédula Profesional</b>
                            <br />
                            {professionalId}
                        </li>
                    )}
                    {academicTitles?.map((academicTitle) => (
                        <li>
                            <b>{academicTitle.title}</b>
                            <br />
                            {academicTitle.professionalId}
                        </li>
                    ))}
                </ul>
            </details-card-section>
        )
    }
</div>

<style>
    .details-card {
        background: var(--tertiary-light);
        border-radius: 32px;
        padding: 48px;
        margin: 0;
        display: flex;
        flex-direction: column;
        font-family: 'Red Hat Display', sans-serif;
        width: 100%;
        max-width: 100%;
        min-width: 0;
        box-sizing: border-box;
        overflow: hidden;
        flex: 1;
    }

    .details-card-section {
        margin-bottom: 32px;
    }

    .details-card-section:last-of-type {
        margin-bottom: 0;
    }

    .details-card-section-title {
        font-size: 28px;
        font-weight: 700;
        color: var(--primary-dark);
        margin: 0 0 16px 0;
        line-height: 1.2;
        font-family: 'Gelasio', sans-serif;
        word-wrap: break-word;
        overflow-wrap: break-word;
    }

    .details-card-section-subtitle {
        font-size: 18px;
        font-weight: 700;
        color: var(--primary-dark);
        line-height: 1.3;
        margin: 0 0 6px 0;
        font-family: 'Red Hat Display', sans-serif;
    }

    .details-card-two-columns {
        width: 100%;
        display: flex;
        flex-direction: row;
        gap: 24px;
        justify-content: space-between;
        min-width: 0;
    }

