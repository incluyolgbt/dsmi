---
import ServicesList from './ServicesList.astro';

interface Props {
    biography: string;
    services: { name: string; price: string }[];
    profileId?: string;
    profileName?: string;
    professionalId?: string;
    contact: {
        email?: string;
        phoneNumber?: string;
        whatsApp?: string;
    };
    socialMedia: {
        name: string;
        handle: string;
        url: string;
    }[];
    academicTitles: {
        title: string;
        professionalId: string;
    }[];
}

const {
    biography,
    services,
    profileId,
    profileName,
    professionalId,
    contact,
    socialMedia,
    academicTitles,
} = Astro.props;

