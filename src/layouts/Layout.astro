---
import { ClientRouter } from 'astro:transitions';
import Footer from '../components/footer/FooterV2.astro';
import Header from '../components/header/Header.astro';
---

<!doctype html>
<html lang="es-MX">
    <head>
        <meta charset="UTF-8" />
        <meta
            name="viewport"
            content="width=device-width, initial-scale=1.0, viewport-fit=cover"
        />
        <link rel="icon" href="/favicon.ico" sizes="any" />
        <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
        <meta name="generator" content={Astro.generator} />
        <title>Directorio de Salud Mental LGBTQ+</title>

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Gelasio:ital,wght@0,400..700;1,400..700&family=Red+Hat+Display:ital,wght@0,300..900;1,300..900&display=swap"
            rel="stylesheet"
        />

        <meta property="og:type" content="website" />
        <meta
            property="og:image"
            content="https://kkwxkbmjdoravcbyanzd.supabase.co/storage/v1/object/public/resources/ogimage.png"
        />

        <script is:inline>
            if (
                new URLSearchParams(window.location.search).get(
                    'x-no-track'
                ) === 'true'
            ) {
                localStorage.setItem('umami.disabled', 1);
            }
        </script>

        <script
            defer
            src="https://v2-dsmi-a.saludmental.lgbt/recorder.js"
            data-website-id="251a4835-e9c1-4de6-9a76-f452f1f938bc"
            data-sample-rate="1"
            data-mask-level="moderate"
            data-max-duration="300000"></script>

        <script
            defer
            src="https://v2-dsmi-a.saludmental.lgbt/script.js"
            data-website-id="251a4835-e9c1-4de6-9a76-f452f1f938bc"
            data-performance="true"></script>

        <ClientRouter />
    </head>

    <body>
        <Header />
        <main id="main-content">
            <slot />
        </main>
        <Footer />
    </body><!-- Global Styles -->
    <style is:global>
        :root {
            /* Colors */
            --primary-dark: #1b1b3a;
            --primary-light: #b7b5e4;

            --secondary-light: #f6f1d1;
            --secondary-dark: #2a2a3e;
            --tertiary-light: #f6f5fc;

            --light-primary-text: #ffffff;
            --light-text-secondary: rgba(255, 255, 255, 0.8);
            --dark-text-secondary: rgb(40, 40, 75);
        }

        html,
        body {
            margin: 0;
            width: 100%;
            min-height: 100%;
            background-color: #fff;
            -webkit-text-size-adjust: 100%;
            -moz-text-size-adjust: 100%;
            text-size-adjust: 100%;
        }

        body {
            min-height: 100vh;
            min-height: 100dvh;
            display: flex;
            flex-direction: column;
        }

        #main-content {
            flex: 1 0 auto;
            margin-top: 105px;

            /* Keep content within safe area on iOS */
            padding-left: env(safe-area-inset-left);
            padding-right: env(safe-area-inset-right);
            padding-bottom: env(safe-area-inset-bottom);

            @media (max-width: 768px) {
                margin-top: 100px;
            }
        }

        *,
        *::before,
        *::after {
            box-sizing: border-box;
        }
    </style>
</html>
