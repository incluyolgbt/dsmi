---
import Layout from '../../layouts/Layout.astro';
import { Content as FaqContent } from '../../content/faq.md';
---

<title>Preguntas Frecuentes - Directorio de Salud Mental LGBTQ+</title>
<meta
    name="description"
    content="Encuentra respuestas a las preguntas más frecuentes sobre el Directorio de Salud Mental LGBTQ+."
/>
<link rel="canonical" href={`https://saludmental.lgbt/preguntas-frecuentes/`} />
<meta name="robots" content="index, follow" />

<Layout>
    <section class="faq-page">
        <article class="faq-content">
            <FaqContent />
        </article>
    </section>
</Layout>

<style>
    .faq-page {
        display: grid;
        gap: 24px;
        max-width: 1200px;
        margin: 0 auto;
        padding: 1.5rem;
        color: var(--secondary-dark);
    }

    .faq-header {
        display: grid;
        gap: 8px;
        padding-top: 0.8rem;
    }

    .faq-eyebrow {
        margin: 0;
        color: var(--dark-text-secondary);
        font-family: 'Red Hat Display', sans-serif;
        font-size: 14px;
        font-weight: 800;
        letter-spacing: 0.7px;
        line-height: 1.3;
        text-transform: uppercase;
    }

    h1 {
        margin: 0;
        color: var(--primary-dark);
        font-family: 'Gelasio', sans-serif;
        font-size: clamp(36px, 6vw, 56px);
        font-weight: 900;
        line-height: 1.05;
    }

    .faq-content {
        width: 100%;
        max-width: 900px;
        margin: 0 auto;
        padding: 48px;
        border-radius: 32px;
        background: var(--tertiary-light);
        font-family: 'Red Hat Display', sans-serif;
        overflow: hidden;
    }

    .faq-content :global(h2) {
        margin: 0 0 16px;
        color: var(--primary-dark);
        font-family: 'Gelasio', sans-serif;
        font-size: 28px;
        font-weight: 700;
        line-height: 1.2;
        overflow-wrap: break-word;
    }

    .faq-content :global(h2:not(:first-child)) {
        margin-top: 40px;
        padding-top: 32px;
        border-top: 1px solid rgba(27, 27, 58, 0.14);
    }

    .faq-content :global(p) {
        margin: 0 0 18px;
        color: var(--secondary-dark);
        font-size: 18px;
        font-weight: 500;
        line-height: 1.65;
    }

    .faq-content :global(p:last-child) {
        margin-bottom: 0;
    }

    .faq-content :global(a) {
        color: var(--primary-dark);
        font-weight: 800;
        text-decoration-color: var(--primary-light);
        text-decoration-thickness: 3px;
        text-underline-offset: 4px;
        transition:
            color 0.2s ease,
            text-decoration-color 0.2s ease;
    }

    .faq-content :global(a:hover) {
        color: #a78bfa;
        text-decoration-color: currentColor;
    }

    .faq-content :global(strong) {
        color: var(--primary-dark);
        font-weight: 800;
    }

    @media (max-width: 640px) {
        .faq-page {
            gap: 20px;
            padding: 1.75rem 1rem 1rem;
        }

        .faq-header {
            padding-top: 0;
        }

        .faq-content {
            padding: 32px 24px;
            border-radius: 24px;
        }

        .faq-content :global(h2) {
            font-size: 24px;
        }

        .faq-content :global(p) {
            font-size: 16px;
        }
    }
</style>
